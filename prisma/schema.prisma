datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  tag       String
  date      String
  excerpt   String
  body      String   @default("")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id     String @id // "2026-04-02" format
  status String    // "available" | "booked"
}
